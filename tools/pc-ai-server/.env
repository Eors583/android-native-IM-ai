# 监听配置（手机连接这个地址/端口）
AIIM_HOST=0.0.0.0
AIIM_PORT=8080

# 机器人信息
AIIM_BOT_NAME=AI助手
AIIM_SYSTEM_PROMPT=你是一个简洁、有帮助的中文聊天助手，在局域网聊天室里与用户对话。

# 后端类型：ollama 或 openai
AIIM_BACKEND=ollama

# Ollama 配置（当 AIIM_BACKEND=ollama 生效）
AIIM_OLLAMA_URL=http://127.0.0.1:11434
AIIM_OLLAMA_MODEL=qwen3:0.6b

# OpenAI 兼容配置（当 AIIM_BACKEND=openai 生效）
AIIM_OPENAI_BASE_URL=http://127.0.0.1:1234
AIIM_OPENAI_MODEL=local-model

# 模型请求超时（秒）
AIIM_LLM_TIMEOUT=120